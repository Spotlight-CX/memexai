{
  "name": "memexai-root",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:core && bun run build:service && bun run build:sdk && bun run build:admin-cli && bun run build:demo",
    "build:core": "bun run --cwd packages/core build",
    "build:admin-cli": "bun run --cwd packages/admin-cli build",
    "build:demo": "bun run --cwd apps/demo-agent build",
    "build:service": "bun run --cwd apps/service build",
    "build:sdk": "bun run --cwd packages/sdk build",
    "demo:agent": "bun run --cwd apps/demo-agent start",
    "demo:inspect": "bun run --cwd apps/demo-agent inspect",
    "dev": "bun run --cwd apps/service dev",
    "dev:admin": "bun run --cwd apps/service dev:admin",
    "admin": "node packages/admin-cli/dist/cli.js --database-url postgresql://memexai:memexai@localhost:5433/memexai",
    "admin:dev": "bun run --cwd packages/admin-cli dev -- --database-url postgresql://memexai:memexai@localhost:5433/memexai",
    "seed:admin": "DATABASE_URL=\"postgresql://memexai:memexai@localhost:5433/memexai\" bun run --cwd apps/service seed:admin",
    "publish:packages": "node scripts/build-and-publish.mjs",
    "publish:packages:dry-run": "node scripts/build-and-publish.mjs --dry-run",
    "test": "vitest run",
    "test:unit": "vitest run packages/core/tests/schemas.test.ts packages/core/tests/paths.test.ts packages/core/tests/text-patch.test.ts packages/core/tests/memex.test.ts packages/sdk/tests/client.test.ts packages/sdk/tests/adapters.test.ts apps/service/tests/config.test.ts",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "packageManager": "bun@1.3.10"
}
