{
  "name": "memexai-root",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:service && bun run build:sdk && bun run build:demo",
    "build:demo": "bun run --cwd apps/demo-agent build",
    "build:service": "bun run --cwd apps/service build",
    "build:sdk": "bun run --cwd packages/sdk build",
    "demo:agent": "bun run --cwd apps/demo-agent start",
    "demo:inspect": "bun run --cwd apps/demo-agent inspect",
    "dev": "bun run --cwd apps/service dev",
    "dev:admin": "bun run --cwd apps/service dev:admin",
    "seed:admin": "DATABASE_URL=\"postgresql://memexai:memexai@localhost:5433/memexai\" bun run --cwd apps/service seed:admin",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "packageManager": "bun@1.3.10"
}
