{
  "name": "@memexai/sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK and agent tool adapters for MemexAI persistent memory.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/openai": {
      "types": "./dist/adapters/openai.d.ts",
      "import": "./dist/adapters/openai.js"
    },
    "./adapters/vercel-ai": {
      "types": "./dist/adapters/vercel-ai.d.ts",
      "import": "./dist/adapters/vercel-ai.js"
    },
    "./adapters/langchain": {
      "types": "./dist/adapters/langchain.d.ts",
      "import": "./dist/adapters/langchain.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/adapters/openai.ts src/adapters/vercel-ai.ts src/adapters/langchain.ts --format esm --dts --platform neutral --target es2022 --out-dir dist --clean",
    "prepublishOnly": "bun run build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "ai": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spotlight-CX/memexai.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Spotlight-CX/memexai/issues"
  },
  "homepage": "https://github.com/Spotlight-CX/memexai#readme",
  "devDependencies": {
    "ai": "^5.0.98",
    "tsup": "^8.5.1"
  }
}
